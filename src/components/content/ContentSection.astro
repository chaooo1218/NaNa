---
interface Props {
  title: string
}

const { title } = Astro.props
---

<section class="rounded-2xl border border-border bg-card p-5 sm:p-6">
  <h2 class="text-base font-bold text-foreground">{title}</h2>
  <div class="mt-3 text-sm leading-6 text-muted-foreground">
    <slot />
  </div>
</section>
