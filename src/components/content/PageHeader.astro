---
interface Props {
  eyebrow?: string
  title: string
  description: string
}

const { eyebrow, title, description } = Astro.props
---

<header class="border-b border-border/70 bg-card">
  <div class="mx-auto max-w-2xl px-4 py-8 sm:px-6 sm:py-10">
    {eyebrow !== undefined && <p class="text-xs font-semibold text-primary">{eyebrow}</p>}
    <h1 class="mt-1 text-2xl font-bold text-foreground sm:text-3xl">{title}</h1>
    <p class="mt-3 max-w-xl text-sm leading-6 text-muted-foreground">{description}</p>
  </div>
</header>
