---
import type { RestaurantDetailViewModel } from "@/types/restaurant"

interface Props {
  restaurant: RestaurantDetailViewModel
}

const { restaurant } = Astro.props
---

<main class="mx-auto max-w-2xl px-4 py-5 sm:px-6 sm:py-8">
  <a href="/" class="text-sm font-semibold text-primary">返回附近店家</a>

  <section class="mt-4 overflow-hidden rounded-2xl border border-border bg-card shadow-[0_10px_30px_-22px_rgba(16,24,40,0.26)]">
    <img src={restaurant.coverImage} alt={`${restaurant.name} 店面示意`} class="h-44 w-full object-cover sm:h-56" />
    <div class="p-5">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <div class="flex flex-wrap items-center gap-2">
            <p class="text-xs font-semibold text-primary">測試店家資料</p>
            {restaurant.sponsorLabel !== null && <span class="rounded-full bg-secondary px-2 py-0.5 text-[11px] font-semibold text-primary">{restaurant.sponsorLabel}</span>}
          </div>
          <h1 class="mt-1 text-2xl font-bold text-foreground">{restaurant.name}</h1>
        </div>
        <span class:list={["shrink-0 rounded-full px-2.5 py-1 text-xs font-semibold", restaurant.isOpen ? "bg-emerald-50 text-emerald-700" : "bg-muted text-muted-foreground"]}>
          {restaurant.openLabel}
        </span>
      </div>
      <p class="mt-3 text-lg font-bold text-foreground">{restaurant.primarySignalLabel}</p>
      <p class="mt-2 text-sm text-muted-foreground">{restaurant.distanceLabel}・{restaurant.waitTimeLabel}</p>
      <div class="mt-3 flex flex-wrap gap-1.5 text-xs text-muted-foreground">
        <span>{restaurant.categoryLabel}</span>
        {restaurant.tags.map((tag) => <span class="rounded-full bg-secondary px-2 py-0.5">{tag}</span>)}
      </div>
      <p class="mt-4 text-xs text-muted-foreground">{restaurant.freshnessLabel}</p>
      <div class="mt-5 flex flex-wrap gap-2">
        <a href={restaurant.menuHref} class:list={["rounded-full px-4 py-2 text-sm font-semibold", restaurant.isOpen ? "bg-primary text-primary-foreground" : "border border-border bg-card text-primary"]}>
          {restaurant.onlineOrderLabel}
        </a>
        <a href={restaurant.menuHref} class="rounded-full border border-border bg-card px-4 py-2 text-sm font-semibold text-primary">查看菜單</a>
      </div>
    </div>
  </section>

  <section class="mt-4 space-y-4">
    <article class="rounded-2xl border border-border bg-card p-5">
      <h2 class="text-base font-bold text-foreground">店家簡介</h2>
      <p class="mt-2 text-sm leading-6 text-muted-foreground">{restaurant.description}</p>
    </article>

    <article class="rounded-2xl border border-border bg-card p-5">
      <h2 class="text-base font-bold text-foreground">營業時間</h2>
      <dl class="mt-3 grid gap-2 text-sm">
        {restaurant.businessHours.map((item) => (
          <div class="flex items-center justify-between gap-4 border-b border-border/60 pb-2 last:border-0 last:pb-0">
            <dt class="font-medium text-foreground">{item.dayLabel}</dt>
            <dd class="text-muted-foreground">{item.hoursLabel}</dd>
          </div>
        ))}
      </dl>
    </article>

    <article class="rounded-2xl border border-border bg-card p-5">
      <h2 class="text-base font-bold text-foreground">店家注意事項</h2>
      <div class="mt-3 grid gap-3">
        {restaurant.notices.map((notice) => (
          <div class="border-l-2 border-primary/25 pl-3">
            <h3 class="text-sm font-semibold text-foreground">{notice.title}</h3>
            <p class="mt-1 text-sm leading-6 text-muted-foreground">{notice.content}</p>
          </div>
        ))}
      </div>
    </article>

    <article class="rounded-2xl border border-dashed border-border bg-secondary/50 p-5">
      <p class="text-xs font-semibold text-primary">地圖建置中</p>
      <h2 class="mt-1 text-base font-bold text-foreground">店家地圖建置中</h2>
      <p class="mt-2 text-sm leading-6 text-muted-foreground">{restaurant.location.summary}</p>
      <p class="mt-2 text-xs text-muted-foreground">位置範圍：{restaurant.location.areaLabel}</p>
    </article>

    <p class="px-1 text-xs leading-5 text-muted-foreground">人流與等待時間為測試資料，僅供附近用餐決策參考，不代表即時保留座位或正式店家營運資訊。</p>
  </section>
</main>
