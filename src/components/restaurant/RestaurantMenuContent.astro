---
import type { RestaurantMenuViewModel } from "@/types/menu"

interface Props {
  menu: RestaurantMenuViewModel
}

const { menu } = Astro.props
---

<main class="mx-auto max-w-2xl px-4 py-5 sm:px-6 sm:py-8">
  <a href={menu.detailHref} class="text-sm font-semibold text-primary">返回店家詳情</a>
  <section class="mt-4 rounded-2xl border border-border bg-card p-5 shadow-[0_10px_30px_-22px_rgba(16,24,40,0.2)]">
    <p class="text-xs font-semibold text-primary">測試菜單預覽</p>
    <h1 class="mt-1 text-2xl font-bold text-foreground">{menu.restaurantName} 菜單</h1>
    <p class="mt-2 text-sm leading-6 text-muted-foreground">{menu.onlineOrderNotice}</p>
  </section>

  <section class="mt-4 space-y-4" aria-label="菜單分類">
    {menu.categories.map((category) => (
      <article class="rounded-2xl border border-border bg-card p-5">
        <h2 class="text-base font-bold text-foreground">{category.name}</h2>
        <div class="mt-3 divide-y divide-border/70">
          {category.items.map((item) => (
            <div class:list={["py-3 first:pt-0 last:pb-0", !item.isAvailable && "opacity-55"]}>
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <div class="flex flex-wrap items-center gap-1.5">
                    <h3 class="text-sm font-semibold text-foreground">{item.name}</h3>
                    {item.badges.map((badge) => <span class="rounded-full bg-secondary px-1.5 py-0.5 text-[10px] font-semibold text-primary">{badge}</span>)}
                    {item.availabilityLabel !== null && <span class="rounded-full bg-muted px-1.5 py-0.5 text-[10px] font-semibold text-muted-foreground">{item.availabilityLabel}</span>}
                  </div>
                  <p class="mt-1 text-sm leading-5 text-muted-foreground">{item.description}</p>
                </div>
                <p class="shrink-0 text-sm font-bold text-foreground">{item.priceLabel}</p>
              </div>
            </div>
          ))}
        </div>
      </article>
    ))}
  </section>

  <div class="mt-5 flex flex-wrap gap-2">
    <a href={menu.detailHref} class="rounded-full bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground">返回店家詳情</a>
    <a href="/#restaurants" class="rounded-full border border-border bg-card px-4 py-2 text-sm font-semibold text-primary">查看附近店家</a>
  </div>
</main>
