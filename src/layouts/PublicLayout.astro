---
import "../styles/global.css"

interface Props {
  title?: string
  description?: string
}

const {
  title = "NaNa｜輔大 514 巷即時人流",
  description = "查看輔大 514 巷附近店家的人流狀態、等待時間與線上點餐資訊。",
} = Astro.props
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#2e417b" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
