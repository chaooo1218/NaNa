---
import Footer from "@/components/layout/Footer.astro"
import HeaderShell from "@/components/layout/HeaderShell.astro"
import RestaurantDetailContent from "@/components/restaurant/RestaurantDetailContent.astro"
import { createRestaurantApi } from "@/lib/api/api-factory"
import { MAX_RESTAURANTS_PER_REQUEST } from "@/lib/api/restaurant-api"
import { toRestaurantDetailViewModel } from "@/lib/mappers/restaurant-detail.mapper"
import PublicLayout from "@/layouts/PublicLayout.astro"
import type { RestaurantDetailViewModel } from "@/types/restaurant"

interface Props {
  restaurant: RestaurantDetailViewModel | null
}

export async function getStaticPaths() {
  const api = createRestaurantApi()

  try {
    const listResponse = await api.getRestaurants({ limit: MAX_RESTAURANTS_PER_REQUEST })
    const paths = await Promise.all(
      listResponse.data.map(async (restaurant) => {
        const detailResponse = await api.getRestaurantBySlug(restaurant.slug)

        return {
          params: { slug: restaurant.slug },
          props: { restaurant: toRestaurantDetailViewModel(detailResponse.data) },
        }
      }),
    )

    return [...paths, { params: { slug: "not-exist" }, props: { restaurant: null } }]
  } catch {
    return [{ params: { slug: "not-exist" }, props: { restaurant: null } }]
  }
}

const { restaurant } = Astro.props
---

<PublicLayout
  title={restaurant === null ? "找不到這間店家｜NaNa 人流" : `${restaurant.name}｜NaNa 人流`}
  description={restaurant === null ? "找不到指定店家。返回 NaNa 人流附近店家列表查看目前支援的店家。" : `查看 ${restaurant.name} 的測試店家資料、人流狀態、等待時間與菜單預覽。`}
  canonicalPath={Astro.url.pathname}
>
  <div class="min-h-dvh bg-background">
    <HeaderShell />
    {
      restaurant === null ? (
        <main class="mx-auto flex min-h-[62dvh] max-w-2xl flex-col justify-center px-4 py-10 sm:px-6">
          <section class="rounded-2xl border border-border bg-card p-6 text-center shadow-[0_10px_32px_-22px_rgba(16,24,40,0.28)]">
            <p class="text-xs font-semibold text-primary">店家資料建置中</p>
            <h1 class="mt-1 text-2xl font-bold text-foreground">找不到這間店家</h1>
            <p class="mt-3 text-sm leading-6 text-muted-foreground">這間店家可能尚未開放、已下架，或網址輸入錯誤。你可以回到附近店家列表查看目前支援的店家。</p>
            <div class="mt-6 flex flex-wrap justify-center gap-2">
              <a href="/" class="rounded-full bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground">回到首頁</a>
              <a href="/#restaurants" class="rounded-full border border-border bg-card px-4 py-2 text-sm font-semibold text-primary">查看附近店家</a>
            </div>
          </section>
        </main>
      ) : (
        <RestaurantDetailContent restaurant={restaurant} />
      )
    }
    <Footer />
  </div>
</PublicLayout>
