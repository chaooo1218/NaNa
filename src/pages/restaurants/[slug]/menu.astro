---
import Footer from "@/components/layout/Footer.astro"
import HeaderShell from "@/components/layout/HeaderShell.astro"
import RestaurantMenuContent from "@/components/restaurant/RestaurantMenuContent.astro"
import { createRestaurantApi } from "@/lib/api/api-factory"
import { MAX_RESTAURANTS_PER_REQUEST } from "@/lib/api/restaurant-api"
import { toRestaurantMenuViewModel } from "@/lib/mappers/menu.mapper"
import PublicLayout from "@/layouts/PublicLayout.astro"
import type { RestaurantMenuViewModel } from "@/types/menu"

interface Props {
  menu: RestaurantMenuViewModel | null
  detailHref: string
}

export async function getStaticPaths() {
  const api = createRestaurantApi()

  try {
    const listResponse = await api.getRestaurants({ limit: MAX_RESTAURANTS_PER_REQUEST })
    const paths = await Promise.all(
      listResponse.data.map(async (restaurant) => {
        try {
          const menuResponse = await api.getRestaurantMenu(restaurant.slug)

          return {
            params: { slug: restaurant.slug },
            props: {
              menu: toRestaurantMenuViewModel(restaurant.name, menuResponse.data),
              detailHref: `/restaurants/${restaurant.slug}`,
            },
          }
        } catch {
          return {
            params: { slug: restaurant.slug },
            props: { menu: null, detailHref: `/restaurants/${restaurant.slug}` },
          }
        }
      }),
    )

    return [...paths, { params: { slug: "not-exist" }, props: { menu: null, detailHref: "/restaurants/not-exist" } }]
  } catch {
    return [{ params: { slug: "not-exist" }, props: { menu: null, detailHref: "/restaurants/not-exist" } }]
  }
}

const { menu, detailHref } = Astro.props
---

<PublicLayout title={menu === null ? "找不到這份菜單｜NaNa" : `${menu.restaurantName} 菜單｜NaNa`}>
  <div class="min-h-dvh bg-background">
    <HeaderShell />
    {
      menu === null ? (
        <main class="mx-auto flex min-h-[62dvh] max-w-2xl flex-col justify-center px-4 py-10 sm:px-6">
          <section class="rounded-2xl border border-border bg-card p-6 text-center shadow-[0_10px_32px_-22px_rgba(16,24,40,0.28)]">
            <p class="text-xs font-semibold text-primary">菜單資料建置中</p>
            <h1 class="mt-1 text-2xl font-bold text-foreground">找不到這份菜單</h1>
            <p class="mt-3 text-sm leading-6 text-muted-foreground">這份菜單可能尚未開放，或店家資料仍在建置中。你可以返回店家詳情或查看附近店家。</p>
            <div class="mt-6 flex flex-wrap justify-center gap-2">
              <a href={detailHref} class="rounded-full bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground">返回店家詳情</a>
              <a href="/#restaurants" class="rounded-full border border-border bg-card px-4 py-2 text-sm font-semibold text-primary">查看附近店家</a>
            </div>
          </section>
        </main>
      ) : (
        <RestaurantMenuContent menu={menu} />
      )
    }
    <Footer />
  </div>
</PublicLayout>
