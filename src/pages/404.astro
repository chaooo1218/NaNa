---
import Footer from "@/components/layout/Footer.astro"
import HeaderShell from "@/components/layout/HeaderShell.astro"
import PublicLayout from "@/layouts/PublicLayout.astro"
---

<PublicLayout title="找不到這個頁面｜NaNa">
  <div class="not-found-route">
    <HeaderShell />
    <main class="mx-auto flex min-h-[68dvh] max-w-md flex-col justify-center px-5 py-10">
      <section class="not-found-card rounded-2xl border border-border bg-card p-6 shadow-[0_10px_32px_-22px_rgba(16,24,40,0.28)]">
        <div class="mb-5 rounded-2xl bg-secondary p-4" aria-hidden="true">
          <svg viewBox="0 0 220 110" class="h-28 w-full text-primary" role="img">
            <path d="M24 78h172" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" opacity="0.25" />
            <path d="M42 78c18-28 44-42 76-42 22 0 40 7 60 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
            <path d="M84 74V42h52v32" fill="none" stroke="currentColor" stroke-width="4" stroke-linejoin="round" />
            <path d="M101 74V56h18v18" fill="none" stroke="currentColor" stroke-width="4" stroke-linejoin="round" />
            <circle cx="168" cy="58" r="9" fill="currentColor" opacity="0.2" />
            <path d="M168 43c11 0 20 9 20 20 0 14-20 31-20 31s-20-17-20-31c0-11 9-20 20-20Z" fill="none" stroke="currentColor" stroke-width="4" />
          </svg>
        </div>

        <p class="text-xs font-semibold text-primary">404</p>
        <h1 class="mt-1 text-2xl font-bold text-foreground">找不到這個頁面</h1>
        <p class="mt-3 text-sm leading-6 text-muted-foreground">
          這個店家頁面可能已移除，或網址輸入錯誤。你可以回到附近店家列表，查看目前可用的人流資訊。
        </p>

        <div class="mt-6 flex flex-wrap gap-2">
          <a href="/" class="rounded-full bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground">
            回到首頁
          </a>
          <a href="/#restaurants" class="rounded-full border border-border bg-card px-4 py-2 text-sm font-semibold text-primary">
            查看附近店家
          </a>
        </div>
      </section>
    </main>
    <Footer />
  </div>
</PublicLayout>
